# Kopiera till .env.local for lokal testning, och satt motsvarande i Vercel.
# Far du automatiskt nar du skapar en KV/Upstash-databas i Vercel (Storage-fliken):
KV_REST_API_URL=
KV_REST_API_TOKEN=
# Ditt hemliga losenord for att fa spara. Valj nagot langt och eget:
ADMIN_TOKEN=byt-mig-till-nagot-hemligt

# For file uploads (video/images). Added automatically when you create a Blob
# store in Vercel (Storage tab). Needed for the "Upload" buttons in the form.
BLOB_READ_WRITE_TOKEN=
